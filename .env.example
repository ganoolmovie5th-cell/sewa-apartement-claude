# ─────────────────────────────────────────────────────────────────
# SewaApartement — Environment Variables
# Copy file ini menjadi .env.local dan isi nilai yang sesuai
# ─────────────────────────────────────────────────────────────────

# Mistral AI API Key — untuk generate artikel blog otomatis setiap minggu
# Daftar / ambil key di: https://console.mistral.ai/api-keys
# Model yang digunakan: mistral-small-latest (hemat & cepat)
# Tanpa key ini, sistem tetap berjalan dengan template fallback
MISTRAL_API_KEY=your-mistral-api-key-here

# Cron Secret — key untuk mengamankan endpoint /api/generate-blog
# Ganti dengan string acak yang aman (minimal 20 karakter)
# Default jika tidak diset: sewa-cron-secret-2024
CRON_SECRET=sewa-cron-secret-2024

# ── Cara setup di Vercel ──────────────────────────────────────────
# 1. Buka dashboard Vercel → project sewa-apartement-claude
# 2. Klik Settings → Environment Variables
# 3. Tambahkan:
#    - Name: MISTRAL_API_KEY   Value: (key dari console.mistral.ai)
#    - Name: CRON_SECRET       Value: sewa-cron-secret-2024
# 4. Klik Save lalu Redeploy
# ─────────────────────────────────────────────────────────────────
