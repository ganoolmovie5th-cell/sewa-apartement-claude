# ─────────────────────────────────────────────────────────────────
# SewaApartement — Environment Variables
# Copy file ini menjadi .env.local dan isi nilai yang sesuai
# ─────────────────────────────────────────────────────────────────

# OpenAI API Key — untuk generate artikel blog otomatis setiap minggu
# Daftar di https://platform.openai.com/api-keys
# Tanpa ini, sistem tetap berjalan dengan template fallback (tidak pakai AI)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cron Secret — key untuk mengamankan endpoint /api/generate-blog
# Ganti dengan string acak yang aman, minimal 32 karakter
# Default jika tidak diset: sewa-cron-secret-2024
CRON_SECRET=sewa-cron-secret-2024

# ── Cara setup di Vercel ──────────────────────────────────────────
# 1. Buka dashboard Vercel → project sewa-apartement-claude
# 2. Klik Settings → Environment Variables
# 3. Tambahkan OPENAI_API_KEY dan CRON_SECRET
# 4. Redeploy project
# ─────────────────────────────────────────────────────────────────
